{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["sentinelops-lite", "deployment"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "",
  "title": "Deployment",
  "uid": "deployment",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Deployment Metadata",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false } }, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [] },
      "targets": [ { "refId": "A", "expr": "deployment_info", "legendFormat": "{{version}}" } ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Container Status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {},
          "thresholds": { "mode": "categorical", "steps": [ { "color": "red", "value": 0 }, { "color": "green", "value": 1 } ] },
          "mappings": [ { "type": "value", "options": { "0": { "text": "Unhealthy" }, "1": { "text": "Healthy" } } } ]
        },
        "overrides": []
      },
      "targets": [ { "refId": "A", "expr": "container_status", "legendFormat": "status" } ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Restart Count",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": {} }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "deployment_restart_total" } ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Deployment Uptime",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "dthms", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "deployment_uptime_seconds", "legendFormat": "uptime" } ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Container Health",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "container_status", "legendFormat": "healthy" } ]
    }
  ]
}
