{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["sentinelops-lite", "ai-agent"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "",
  "title": "AI Agent",
  "uid": "ai-agent",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Current Agent State",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {},
          "thresholds": {
            "mode": "categorical",
            "steps": [
              { "color": "blue", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Idle" }, "1": { "text": "Running" }, "2": { "text": "Waiting" }, "3": { "text": "Approved" }, "4": { "text": "Rejected" }, "5": { "text": "Failed" } } }
          ]
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "max(agent_state)", "legendFormat": "state" } ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Agent State Timeline",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 30, "showPoints": "never" } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "agent_state", "legendFormat": "{{state}}" } ]
    },
    {
      "id": 3,
      "type": "barchart",
      "title": "Task Outcomes",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": {} }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum(agent_tasks_total) by (result)", "legendFormat": "{{result}}" } ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Token Usage (tokens/sec)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum(rate(agent_token_usage_total[5m]))", "legendFormat": "tokens/s" } ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "API Calls (success/failed)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum(rate(agent_api_calls_total[5m])) by (status)", "legendFormat": "{{status}}" } ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "API Response Time (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "agent_api_response_time_seconds", "legendFormat": "resp" } ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Total Decisions",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 22 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": {} }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "agent_total_decisions" } ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Queue Size",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 22 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": {} }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "agent_queue_size" } ]
    },
    {
      "id": 9,
      "type": "gauge",
      "title": "Agent Accuracy",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 22 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "gauge": { "maxValue": 1, "minValue": 0 } } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "agent_accuracy" } ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Execution Time (last / avg)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "agent_execution_time_seconds", "legendFormat": "last" },
        { "refId": "B", "expr": "agent_avg_execution_time_seconds", "legendFormat": "avg" }
      ]
    }
  ]
}
