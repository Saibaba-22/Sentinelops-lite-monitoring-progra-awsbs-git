{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["sentinelops-lite", "overview"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "",
  "title": "Operations Overview",
  "uid": "overview",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests / second",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": {} }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum(rate(app_requests_total[1m]))" } ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate %",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {},
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 5 } ] }
        },
        "overrides": []
      },
      "targets": [ { "refId": "A", "expr": "(sum(rate(app_errors_total[1m])) / sum(rate(app_requests_total[1m]))) * 100" } ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "CPU Usage %",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {},
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 80 } ] }
        },
        "overrides": []
      },
      "targets": [ { "refId": "A", "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)" } ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Memory Usage %",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {},
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 85 } ] }
        },
        "overrides": []
      },
      "targets": [ { "refId": "A", "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100" } ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Application Traffic",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum(rate(app_requests_total[1m]))", "legendFormat": "rps" } ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "AI Agent State",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 30, "showPoints": "never" } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "agent_state", "legendFormat": "{{state}}" } ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Deployment",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "inspect": false } }, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [] },
      "targets": [ { "refId": "A", "expr": "deployment_info" } ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Application Uptime",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "dthms", "custom": {} }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "app_uptime_seconds" } ]
    }
  ]
}
