# Elastic Beanstalk — reverse proxy & health-check tuning
# Works with the multi-container Docker platform (the nginx container defined
# in Dockerrun.aws.json terminates traffic on port 80 and proxies to the app).
option_settings:
  aws:elasticbeanstalk:application:
    Application Healthcheck URL: /health
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /health
    Port: 80
  aws:elasticbeanstalk:cloudwatch:logs:
    StreamLogs: true
    DeleteOnTerminate: false
    RetentionInDays: 14
