# Elastic Beanstalk — centralised logging
# Ensures container logs (app, prometheus, grafana) are surfaced under
# /var/log so they are collected by Elastic Beanstalk / CloudWatch Logs.
files:
  "/etc/logrotate.d/sentinelops":
    mode: "000644"
    owner: root
    group: root
    content: |
      /var/log/containers/*.log {
          rotate 7
          daily
          missingok
          notifempty
          compress
          delaycompress
      }
